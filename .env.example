# .env.example — Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.

# Gmail address used to SEND alert emails
EMAIL_ADDRESS=your-email@gmail.com

# Gmail App Password (NOT your regular password).
# Create one at: https://myaccount.google.com/apppasswords
EMAIL_APP_PASSWORD=your-app-password-here

# Recipient email address(es) for alerts.
# Separate multiple addresses with commas — no spaces around commas.
# If not set, falls back to EMAIL_ADDRESS above.
TO_EMAILS=recipient1@gmail.com,recipient2@gmail.com
